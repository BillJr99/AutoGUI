{
  "openwebui": {
    "base_url": "http://localhost:3000",
    "api_key": "sk-your-openwebui-api-key-here",
    "model": "llama3.1:70b",
    "temperature": 0.2,
    "max_tokens": 4096,
    "timeout_seconds": 120
  },
  "prompts_dir": "prompts",
  "_install_comment": "Set install_dependencies=true to run scripts/install-dependencies.* at startup (system + Python + Playwright + pi-extension Node deps).",
  "install_dependencies": false,
  "agent": {
    "max_iterations": 30,
    "confirm_destructive": true,
    "vision_screenshots": true,
    "record_trace": true,
    "trace_dir": "logs/traces",
    "_skills_comment": "Skills (replayable macros) are OFF by default. Set skills_enabled=true to record successful tool sequences as named, replayable skills. When enabled, the standalone agent stores them in ./skills/skills.jsonl relative to the project root — separate from the pi-extension's own library at pi-extension/runtime/skills/skills.jsonl. The directory is git-ignored and created automatically on first save. suggest_skills controls whether matching skills are surfaced at task start; it has no effect when skills_enabled=false.",
    "skills_enabled": false,
    "suggest_skills": true,
    "skills_path": "skills/skills.jsonl",
    "planner": {
      "_comment": "Pre-execution planning pass; one extra LLM call up front but more coherent multi-step traces.",
      "enabled": true
    },
    "controller": {
      "_comment": "Typed plan + step-by-step executor. When enabled, the planner emits a JSON plan and each step runs in its own scoped history with its own iteration budget. Replan triggers automatically on persistent failures.",
      "enabled": false,
      "step_max_iterations": 8,
      "step_max_retries": 2,
      "auto_resume": true,
      "replan_on_block": true
    },
    "artifacts": {
      "_comment": "Content-addressed store for large observations (file bodies, command stdout, OCR snippets). The model fetches by id with get_artifact when it actually needs the body.",
      "dir": "logs/artifacts"
    },
    "progress": {
      "_comment": "Task progress markers persisted across runs so a crash or abort can resume mid-task.",
      "dir": "logs/progress"
    },
    "subagent": {
      "_comment": "Read-only subagent for pure-lookup questions; keeps the main conversation small.",
      "enabled": true,
      "max_tool_calls": 4
    },
    "bon": {
      "_comment": "Best-of-N action sampling. Samples n completions and picks the best. Increases token cost on uncertain steps.",
      "enabled": true,
      "n": 3,
      "temperature": 0.7,
      "trigger_on_recent_failure": true,
      "trigger_on_validator_disagreement": true
    },
    "screen_record": {
      "_comment": "Rolling screen buffer; flushes to an animated GIF on tool failure.",
      "enabled": true,
      "fps": 5,
      "buffer_seconds": 5.0,
      "max_width": 960,
      "out_dir": "screenshots/failures"
    }
  },
  "tools": {
    "shell_timeout_seconds": 30,
    "screenshot_dir": "screenshots",
    "max_screenshot_width": 1280,
    "perception_cache_ttl_seconds": 0.5,
    "allowed_shell": true,
    "allowed_filesystem": true,
    "allowed_desktop": true,
    "allowed_browser": true
  },
  "browser": {
    "_comment": "Settings for the Playwright-driven browser backend (used when allowed_browser=true).",
    "headless": false,
    "screenshot_dir": "screenshots/browser",
    "user_data_dir": "",
    "viewport": {"width": 1280, "height": 800}
  },
  "logging": {
    "level": "INFO",
    "file": "logs/agent.log",
    "max_bytes": 10485760,
    "backup_count": 3
  },
  "tui": {
    "theme": "dark",
    "show_tool_calls": true,
    "show_token_counts": true,
    "history_file": "logs/history.jsonl"
  },
  "safety": {
    "command_confirm_delay_seconds": 5,
    "dry_run": false,
    "allowed_apps": [],
    "blocked_window_titles": [],
    "fs_write_snapshot_dir": ""
  }
}
