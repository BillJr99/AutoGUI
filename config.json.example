{
  "openwebui": {
    "base_url": "http://localhost:3000",
    "api_key": "sk-your-openwebui-api-key-here",
    "model": "llama3.1:70b",
    "temperature": 0.2,
    "max_tokens": 4096,
    "timeout_seconds": 120
  },
  "openwebui_fast": {
    "_comment": "Optional second client used for cheap auxiliary calls (validator). Omit this block to reuse the primary client for everything.",
    "base_url": "http://localhost:3000",
    "api_key": "sk-your-openwebui-api-key-here",
    "model": "llama3.1:8b",
    "temperature": 0.0,
    "max_tokens": 1024,
    "timeout_seconds": 60
  },
  "prompts_dir": "prompts",
  "agent": {
    "max_iterations": 30,
    "confirm_destructive": true,
    "vision_screenshots": true,
    "record_trace": true,
    "trace_dir": "logs/traces",
    "suggest_skills": true,
    "skills_path": "~/.autogui/skills.jsonl",
    "planner": {
      "_comment": "Pre-execution planning pass; one extra LLM call up front but more coherent multi-step traces. Uses openwebui_fast when configured.",
      "enabled": true
    },
    "bon": {
      "_comment": "Best-of-N action sampling. Multiplies token cost on uncertain steps.",
      "enabled": false,
      "n": 3,
      "temperature": 0.7,
      "trigger_on_recent_failure": true,
      "trigger_on_validator_disagreement": true
    },
    "screen_record": {
      "_comment": "Rolling screen buffer; flushes to an animated GIF on tool failure.",
      "enabled": true,
      "fps": 5,
      "buffer_seconds": 5.0,
      "max_width": 960,
      "out_dir": "screenshots/failures"
    }
  },
  "tools": {
    "shell_timeout_seconds": 30,
    "screenshot_dir": "screenshots",
    "max_screenshot_width": 1280,
    "perception_cache_ttl_seconds": 0.5,
    "auto_install_tesseract": false,
    "auto_install_playwright": true,
    "allowed_shell": true,
    "allowed_filesystem": true,
    "allowed_desktop": true,
    "allowed_browser": false
  },
  "browser": {
    "_comment": "Settings for the optional Playwright-driven browser backend.",
    "headless": false,
    "screenshot_dir": "screenshots/browser",
    "user_data_dir": "",
    "viewport": {"width": 1280, "height": 800}
  },
  "logging": {
    "level": "INFO",
    "file": "logs/agent.log",
    "max_bytes": 10485760,
    "backup_count": 3
  },
  "tui": {
    "theme": "dark",
    "show_tool_calls": true,
    "show_token_counts": false,
    "history_file": "logs/history.jsonl"
  },
  "safety": {
    "command_confirm_delay_seconds": 5,
    "dry_run": false,
    "allowed_apps": [],
    "blocked_window_titles": [],
    "fs_write_snapshot_dir": ""
  }
}
