{
  "openwebui": {
    "base_url": "http://localhost:3000",
    "api_key": "sk-your-openwebui-api-key-here",
    "model": "llama3.1:70b",
    "temperature": 0.2,
    "max_tokens": 4096,
    "timeout_seconds": 120
  },
  "prompts_dir": "prompts",
  "_install_comment": "Set install_dependencies=true to run scripts/install-dependencies.* at startup (system + Python + Playwright + pi-extension Node deps).",
  "install_dependencies": false,
  "agent": {
    "max_iterations": 30,
    "confirm_destructive": true,
    "vision_screenshots": true,
    "record_trace": true,
    "trace_dir": "logs/traces",
    "_skills_comment": "skills_enabled controls CREATION ONLY. When false (the default) the agent will NOT register skill_save and will NOT write a skills/ directory or skills.jsonl on disk — but skill_list, skill_run, and the candidate-skills suggestion at task start are always available, so any skills already on disk remain readable and replayable. Set skills_enabled=true to allow new skills to be recorded. The standalone agent uses ./skills/skills.jsonl relative to the project root, intentionally distinct from the pi-extension's pi-extension/runtime/skills/skills.jsonl so each side has its own library. The directory is git-ignored and created lazily the first time skill_save fires. suggest_skills toggles the candidate-skills block at task start regardless of skills_enabled.",
    "skills_enabled": false,
    "suggest_skills": true,
    "skills_path": "skills/skills.jsonl",
    "_drift_anchor_comment": "Post-action world snapshot attached to each session step so 'replay --drift-check' can flag steps whose live state has shifted vs. the recording. window_titles capture is essentially free; capture_phash adds a screenshot per step (a few percent overhead) and is opt-in.",
    "drift_anchor": {
      "enabled": true,
      "capture_phash": false
    },
    "planner": {
      "_comment": "Pre-execution planning pass; one extra LLM call up front but more coherent multi-step traces.",
      "enabled": true
    },
    "controller": {
      "_comment": "Typed plan + step-by-step executor. ON by default. The planner emits a JSON plan and each step runs in its own scoped history with its own iteration budget. Replan triggers automatically on persistent failures. critique_enabled adds one extra LLM call after the planner to review the plan; preflight_enabled gates resource availability before any UI action; predicate_check_enabled verifies typed post-conditions deterministically; visual_diff_enabled flags state-changing actions whose screen pixels barely moved; watchdog_stall_threshold flags a step as stuck after the same (state+action) signature recurs N iterations in a row (0 = disabled). Set enabled=false to fall back to the legacy single-loop ReAct executor.",
      "enabled": true,
      "step_max_iterations": 8,
      "step_max_retries": 2,
      "auto_resume": true,
      "replan_on_block": true,
      "critique_enabled": true,
      "preflight_enabled": true,
      "predicate_check_enabled": true,
      "visual_diff_enabled": true,
      "watchdog_stall_threshold": 3
    },
    "artifacts": {
      "_comment": "Stable-id store for large observations (file bodies, command stdout, OCR snippets). Each capture gets a fresh artifact://<id>; identical bodies are NOT deduped — the store is an append-only log of what the agent saw and when. The model fetches by id with get_artifact when it needs the body.",
      "dir": "logs/artifacts"
    },
    "progress": {
      "_comment": "Task progress markers persisted across runs so a crash or abort can resume mid-task.",
      "dir": "logs/progress"
    },
    "memory": {
      "_comment": "Per-app failure/success histograms + free-form notes, surfaced to the planner as 'app memory hints' so future tasks against the same app see what worked / failed before. enabled controls CREATION ONLY (mirrors skills_enabled): when false (the default) memory_get and the planner's app-memory hints continue to read whatever is already at dir, but memory_note is not registered, the controller does NOT auto-record successes/failures, and no memory/ directory is created. The standalone agent stores at ./memory/ (git-ignored, distinct from pi-extension/runtime/memory/) — both directories are created lazily the first time something is written.",
      "enabled": false,
      "dir": "memory"
    },
    "budget": {
      "_comment": "Per-task hard ceilings. 0 = no ceiling for that dimension. Exceeding any ceiling fires a budget_exceeded event and ends the task before the next step runs.",
      "max_tool_calls": 0,
      "max_chat_calls": 0,
      "max_total_tokens": 0,
      "max_seconds": 0
    },
    "subagent": {
      "_comment": "Read-only subagent for pure-lookup questions; keeps the main conversation small.",
      "enabled": true,
      "max_tool_calls": 4
    },
    "bon": {
      "_comment": "Best-of-N action sampling. Samples n completions and picks the best. Increases token cost on uncertain steps.",
      "enabled": true,
      "n": 3,
      "temperature": 0.7,
      "trigger_on_recent_failure": true,
      "trigger_on_validator_disagreement": true
    },
    "screen_record": {
      "_comment": "Rolling screen buffer; flushes to an animated GIF on tool failure.",
      "enabled": true,
      "fps": 5,
      "buffer_seconds": 5.0,
      "max_width": 960,
      "out_dir": "screenshots/failures"
    }
  },
  "tools": {
    "shell_timeout_seconds": 30,
    "screenshot_dir": "screenshots",
    "max_screenshot_width": 1280,
    "perception_cache_ttl_seconds": 0.5,
    "allowed_shell": true,
    "allowed_filesystem": true,
    "allowed_desktop": true,
    "allowed_browser": false
  },
  "browser": {
    "_comment": "Settings for the Playwright-driven browser backend (used when allowed_browser=true).",
    "headless": false,
    "screenshot_dir": "screenshots/browser",
    "user_data_dir": "",
    "viewport": {"width": 1280, "height": 800}
  },
  "logging": {
    "level": "INFO",
    "file": "logs/agent.log",
    "max_bytes": 10485760,
    "backup_count": 3
  },
  "tui": {
    "theme": "dark",
    "show_tool_calls": true,
    "show_token_counts": true,
    "history_file": "logs/history.jsonl"
  },
  "safety": {
    "command_confirm_delay_seconds": 5,
    "dry_run": false,
    "allowed_apps": [],
    "blocked_window_titles": [],
    "fs_write_snapshot_dir": ""
  },
  "screen_observer": {
    "_comment": "Optional integration with OS Screen Observer (github.com/BillJr99/OSScreenObserver). When enabled=true AutoGUI probes the server and uses it as a fallback/enhancement for window listing, accessibility tree access (find_element, get_window_tree), and a new describe_screen capability — all with graceful degradation if the server is not reachable. Start OSScreenObserver with: python main.py --mode inspect",
    "enabled": false,
    "base_url": "http://127.0.0.1:5001",
    "timeout_seconds": 2.0
  }
}
